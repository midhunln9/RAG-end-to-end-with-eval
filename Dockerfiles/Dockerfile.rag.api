FROM python:3.12-slim

WORKDIR /app

RUN pip install uv

RUN apt-get update && apt-get install -y \
    build-essential \
    gcc \
    g++ \
    libffi-dev \
    libbz2-dev \
    liblzma-dev \
    libz-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml /app

COPY uv.lock /app

RUN uv sync --frozen

COPY rag_pipeline /app/rag_pipeline

CMD ["uv", "run", "uvicorn", "rag_pipeline.api.main:app", "--host", "0.0.0.0", "--port", "8000"]